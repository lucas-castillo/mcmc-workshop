  date = {2019-05},
  journaltitle = {Developmental Science},
  shortjournal = {Dev Sci},
  volume = {22},
  number = {3},
  issn = {1363-755X, 1467-7687},
  doi = {10.1111/desc.12769},
  url = {https://onlinelibrary.wiley.com/doi/abs/10.1111/desc.12769},
  urldate = {2020-02-27},
  abstract = {It is well established that the temporal proximity of two events is a fundamental cue to causality. Recent research with adults has shown that this relation is bidirectional: events that are believed to be causally related are perceived as occurring closer together in time—the so‐called temporal binding effect. Here, we examined the developmental origins of temporal binding. Participants predicted when an event that was either caused by a button press, or preceded by a non‐causal signal, would occur. We demonstrate for the first time that children as young as 4 years are susceptible to temporal binding. Binding occurred both when the button press was executed via intentional action, and when a machine caused it. These results suggest binding is a fundamental, early developing property of perception and grounded in causal knowledge.},
  langid = {english},
  file = {/home/lucas/Zotero_Articles/Blakey et al. - 2019 - When causality shapes the experience of time Evid.pdf}
}

