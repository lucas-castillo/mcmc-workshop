@article{shahar2019CreditAssignmentStateindependent,
  title = {Credit Assignment to State-Independent Task Representations and Its Relationship with Model-Based Decision Making},
  author = {Shahar, Nitzan and Moran, Rani and Hauser, Tobias U. and Kievit, Rogier A. and McNamee, Daniel and Moutoussis, Michael and {NSPN Consortium} and Dolan, Raymond J. and Bullmore, Edward and Dolan, Raymond and Goodyer, Ian and Fonagy, Peter and Jones, Peter and Moutoussis, Michael and Hauser, Tobias and Neufeld, Sharon and Romero-Garcia, Rafael and St Clair, Michelle and Vértes, Petra and Whitaker, Kirstie and Inkster, Becky and Prabhu, Gita and Ooi, Cinly and Toseeb, Umar and Widmer, Barry and Bhatti, Junaid and Villis, Laura and Alrumaithi, Ayesha and Birt, Sarah and Bowler, Aislinn and Cleridou, Kalia and Dadabhoy, Hina and Davies, Emma and Firkins, Ashlyn and Granville, Sian and Harding, Elizabeth and Hopkins, Alexandra and Isaacs, Daniel and King, Janchai and Kokorikou, Danae and Maurice, Christina and McIntosh, Cleo and Memarzia, Jessica and Mills, Harriet and O’Donnell, Ciara and Pantaleone, Sara and Scott, Jenny and Fearon, Pasco and Suckling, John and Van Harmelen, Anne-Laura and Kievit, Rogier},
  date = {2019-08-06},
  journaltitle = {Proceedings of the National Academy of Sciences},
  shortjournal = {Proc. Natl. Acad. Sci. U.S.A.},
  volume = {116},
  number = {32},
  pages = {15871--15876},
  issn = {0027-8424, 1091-6490},
  doi = {10.1073/pnas.1821647116},
  url = {https://pnas.org/doi/full/10.1073/pnas.1821647116},
  urldate = {2024-08-15},
  abstract = {Model-free learning enables an agent to make better decisions based on prior experience while representing only minimal knowledge about an environment’s structure. It is generally assumed that model-free state representations are based on outcome-relevant features of the environment. Here, we challenge this assumption by providing evidence that a putative model-free system assigns credit to task representations that are irrelevant to an outcome. We examined data from 769 individuals performing a well-described 2-step reward decision task where stimulus identity but not spatial-motor aspects of the task predicted reward. We show that participants assigned value to spatial-motor representations despite it being outcome irrelevant. Strikingly, spatial-motor value associations affected behavior across all outcome-relevant features and stages of the task, consistent with credit assignment to low-level state-independent task representations. Individual difference analyses suggested that the impact of spatial-motor value formation was attenuated for individuals who showed greater deployment of goal-directed (model-based) strategies. Our findings highlight a need for a reconsideration of how model-free representations are formed and regulated according to the structure of the environment.},
  langid = {english}
}

