@report{russek2021SelectiveOutcomeReinstatement,
  type = {preprint},
  title = {Selective Outcome Reinstatement during Evaluation Drives Heuristics in Risky Choice},
  author = {Russek, Evan and Moran, Rani and Liu, Yunzhe and Dolan, Raymond J and Huys, Quentin JM},
