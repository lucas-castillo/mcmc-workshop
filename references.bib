  shorttitle = {Random Number Generation in Dementia of the {{Alzheimer}} Type},
  author = {Brugger, P and Monsch, A.U and Salmon, D.P and Butters, N},
  date = {1996-02},
  journaltitle = {Neuropsychologia},
