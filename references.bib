@article{bavard2021TwoSidesSame,
  title = {Two Sides of the Same Coin: {{Beneficial}} and Detrimental Consequences of Range Adaptation in Human Reinforcement Learning},
  shorttitle = {Two Sides of the Same Coin},
  author = {Bavard, Sophie and Rustichini, Aldo and Palminteri, Stefano},
  date = {2021-04-02},
  journaltitle = {Science Advances},
  shortjournal = {Sci. Adv.},
  volume = {7},
  number = {14},
