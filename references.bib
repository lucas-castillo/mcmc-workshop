  author = {Lin, Yitong and Zhu, Jian-Qiao and Spicer, Jake and Li, Yun-Xiao and Chater, Nick and Sanborn, Adam},
  abstract = {People systematically deviate from rational Bayesian standards in belief updating, displaying biases such as base-rate neglect and conservatism. Two very different types of model aim to explain these biases: simple heuristics and stochastic sampling approximations of the Bayesian solution, like the Bayesian Sampler. However, neither approach alone accounts for the variety of responses. Here we explore a hybrid Heuristic-Anchored Bayesian Sampler (HABS) which integrates simple heuristics with a Bayesian sampler. In this framework, a simple heuristic provides an initial estimate, which may then be refined through a Bayesian sampling process to approximate the ideal Bayesian posterior. Behaviour thus depends on the size of the sample: if no samples are drawn, a heuristic response is produced, but adding samples will introduce noise while increasing average judgment accuracy. Analyses of data from a new experiment (𝑁 = 200) and re-analysis of data from Stengård et al., 2022 revealed that, in most conditions, this integrative approach outperformed purely heuristic or purely Bayesian models in explaining how people update their beliefs in the medical diagnosis task. Our findings suggest that people flexibly combine mental shortcuts and approximate Bayesian processes, illuminating why some responses appear purely heuristic while others reflect approximate Bayesian updating. Public Significance Statement When making judgments under uncertainty where explicit probabilities are given, there is evidence of simple mental shortcuts on some trials and evidence of approximate statistical reasoning on others. This study found that this pattern of results could be accounted for by a new modeling approach in which individuals start with a heuristic estimate and then refine it through limited mental sampling, which improves the estimates on average. This hybrid process explains why human judgment shows both sharp patterns matching simple rules and smoother patterns approximating optimal inference. This work reconciles competing theories of probabilistic reasoning in a single framework.},
  langid = {english},
  file = {/home/lucas/Zotero/storage/JC362HZM/Lin et al. - Integrating Heuristics and Mental Sampling in Belief Updating.pdf}
}

