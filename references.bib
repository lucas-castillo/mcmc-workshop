  issn = {0956-7976, 1467-9280},
  doi = {10.1177/0956797613476046},
  url = {http://journals.sagepub.com/doi/10.1177/0956797613476046},
  urldate = {2019-11-26},
  abstract = {Traditional approaches to human causal reasoning assume that the perception of temporal order informs judgments of causal structure. In this article, we present two experiments in which people followed the opposite inferential route: Perceptual judgments of temporal order were instead influenced by causal beliefs. By letting participants freely interact with a software-based “physics world,” we induced stable causal beliefs that subsequently determined participants’ reported temporal order of events, even when this led to a reversal of the objective temporal order. We argue that for short timescales, even when temporal-resolution capabilities suffice, the perception of temporal order is distorted to fit existing causal beliefs.},
  langid = {english},
  file = {/home/lucas/Zotero_Articles/Bechlivanidis and Lagnado - 2013 - Does the “Why” Tell Us the “When”.pdf;/home/lucas/Zotero_Articles/Bechlivanidis and Lagnado - 2013 - Does the “Why” Tell Us the “When”2.pdf}
