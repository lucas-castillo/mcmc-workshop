  doi = {10.3758/s13423-013-0542-9},
  url = {https://link.springer.com/10.3758/s13423-013-0542-9},
  urldate = {2024-07-08},
  abstract = {When making decisions on the basis of past experiences, people must rely on their memories. Human memory has many well-known biases, including the tendency to better remember highly salient events. We propose an extreme-outcome rule, whereby this memory bias leads people to overweight the largest gains and largest losses, leading to more risk seeking for relative gains than for relative losses. To test this rule, in two experiments, people repeatedly chose between fixed and risky options, where the risky option led equiprobably to more or less than did the fixed option. As was predicted, people were more risk seeking for relative gains than for relative losses. In subsequent memory tests, people tended to recall the extreme outcome first and also judged the extreme outcome as having occurred more frequently. Across individuals, risk preferences in the riskychoice task correlated with these memory biases. This extreme-outcome rule presents a novel mechanism through which memory influences decision making.},
  langid = {english},
  keywords = {Read},
  file = {/home/lucas/Zotero_Articles/Madan et al. - 2014 - Remembering the best and worst of times Memories .pdf}
}

@article{madan2017RoleMemoryDistinguishing,
