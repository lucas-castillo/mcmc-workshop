@article{oboler2012DangerBigData,
  title = {The Danger of Big Data: {{Social}} Media as Computational Social Science},
  shorttitle = {The Danger of Big Data},
  author = {Oboler, Andre and Welsh, Kristopher and Cruz, Lito},
  date = {2012-06-17},
  journaltitle = {First Monday},
