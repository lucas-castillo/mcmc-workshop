  abstract = {Predictability is a hallmark of poor-quality decision-making during competition. One source of predictability is the strong association between current outcome and future action, as dictated by the reinforcement learning principles of win-stay and lose-shift. We tested the idea that predictability could be reduced during competition by weakening the associations between outcome and action. To do this, participants completed a competitive zero-sum game in which the opponent from the current trial was either replayed (opponent repeat) thereby strengthening the association, or, replaced (opponent change) by a different competitor thereby weakening the association. We observed that win-stay behaviour was reduced during opponent change trials but lose-shift behaviour remained reliably predictable. Consistent with the group data, the number of individuals who exhibited predictable behaviour following wins decreased for opponent change relative to opponent repeat trials. Our data show that future actions are more under internal control following positive relative to negative outcomes, and that externally breaking the bonds between outcome and action via opponent association also allow us to become less prone to exploitation.},
  file = {/home/lucas/Zotero_Articles/Srihaput et al. - 2020 - Switching competitors reduces win-stay but not los.pdf}
}

@article{srisukontamitUsingGenerativeAI,
  title = {Using {{Generative AI}} as a {{Cognitive Architecture}}: {{GPT-based Modelling}} of {{Human-like Behaviour}} in the {{Flanker Task}}},
  author = {Srisukontamit, Peerasit},
  abstract = {Cognitive models have long struggled to reconcile deterministic rule-following with the structured variability of human behaviour. Symbolic architectures capture rules transparently but lack stochasticity, while connectionist approaches produce variability yet often remain opaque. The Eriksen Flanker task provides a stringent benchmark, as its simple rule (“respond to the central target”) robustly induces congruency effects, sequential adaptations, and reaction time (RT) variability. Recent large language models (LLMs) have been proposed as candidate cognitive architectures, but concerns remain that predictive alignment does not guarantee mechanistic insight. This study investigates whether a GPT-like model can reproduce hallmark signatures of cognitive control when trained on structured variants of the Flanker task. We constructed synthetic datasets comprising a Perfect Model, four noise injected variants (irrelevant clutter, flanker dropout, interference substitution, and probabilistic corruption), and a Human-Trained dataset derived from large-scale Lumosity logs. Stimuli were encoded in a 5×5 matrix format to preserve spatial relations, and models were trained using a compact nanoGPT architecture. Sampling-based inference with a stochastic stopping rule linked output uncertainty to simulated RTs via an Erlang -like mapping, yielding positively skewed RT distributions. Results revealed distinct behavioural profiles: the Perfect and near-deterministic models achieved ceiling accuracy but lacked variability; flanker dropout and probabilistic corruption induced strong congruency effects and human-like RT slowdowns; and the human-trained GPT reproduced \textasciitilde 97\% accuracy, closely mirroring the empirical human baseline. These findings demonstrate that GPT-based systems, when paired with principled noise and context manipulations, can act as flexible cognitive architectures. By treating variability as signal rather than error, this approach bridges predictive performance with theoretical explanation, highlighting GPT-based models as experimental platforms for probing human-like cognitive control.},
  langid = {english},
  file = {/home/lucas/Zotero/storage/X2GFBHL2/Srisukontamit - Using Generative AI as a Cognitive Architecture GPT-based Modelling of Human-like Behaviour in the.pdf}
}

