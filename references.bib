@article{mulligan2023MemoryAttentionDouble,
  title = {Memory and Attention: {{A}} Double Dissociation between Memory Encoding and Memory Retrieval},
  shorttitle = {Memory and Attention},
  author = {Mulligan, Neil W. and Spataro, Pietro and West, John T.},
  date = {2023-09},
  journaltitle = {Cognition},
