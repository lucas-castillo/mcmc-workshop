@report{chater2020MacroeconomicImplicationsSampling,
  title = {Macroeconomic {{Implications}} of the {{Sampling Brain}}},
  author = {Chater, Nick and Zhu, Jian-Qiao and Sanborn, Adam N and Spicer, Jake},
  date = {2020},
  institution = {{National Institute of Economic and Social Research}},
  location = {Westminster, London},
  abstract = {Much work in macroeconomics has used either descriptive statistical models or models built on trader interactions to try to understand patterns, such as heavy tails and intermittent periods of high variation, that are observed in financial markets. However, work in psychology has shown that analogous patterns can be produced by a single individual alone, such as in the time series generated by a participant who sits alone in a room attempting to tap a key at a specific regular time interval without any feedback. In this paper, we take the novel step of examining participant behaviour in this tapping task using the same methods used to analyse the time series of financial returns and find that individual decisions in this time estimation task show notably similar behaviours to market movements. While this could be an entirely coincidental feature of complex time series, we propose a possible causal link between the two tasks. As a starting point, we take previous work in which we formalized tapping behaviour as using a sophisticated sampling algorithm for drawing mental samples from a belief distribution about the length of a specific time interval – this provides a way for the brain to approximate fully rational inference. Here we extend that work by proposing a macroeconomic model built on the same mental sampling algorithm, and incorporate the sampling algorithm into a market model in which price fluctuations are driven by variations in beliefs sampled at the individual level. While preliminary, this model matches many of the key behaviours found in real markets, suggesting that the source of macroeconomic patterns may be, at least in part, individual psychology rather than the interactions between individuals.},
  langid = {english},
  file = {/home/lucas/Zotero_Articles/Chater et al. - 2020 - Macroeconomic Implications of the Sampling Brain.pdf}
}

