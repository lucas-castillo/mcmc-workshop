  institution = {PsyArXiv},
  doi = {10.31234/osf.io/drjkg},
  url = {https://osf.io/drjkg},
  urldate = {2023-02-09},
  abstract = {Even though the nature of confidence computations has been the topic of intense interest, little attention has been paid to what confidence response times (cRT) reveal about the underlying confidence computations. Recently, cRTs were found to be negatively correlated with confidence and lower for correct compared to incorrect responses. These findings were assumed to imply the existence of an intrinsic relationship of cRT with confidence and accuracy and were interpreted as evidence that confidence is based on a post-decision evidence accumulation process. However, an alternative possibility is that the relationship of cRT with confidence and accuracy is not intrinsic but is instead mediated by a third factor. Here we examined cRTs in three large datasets from the Confidence Database and found substantial variability between studies and individual subjects in the cRT-confidence and cRT-accuracy relationships. Critically, cRTs were primarily driven by purely motor factors such that the lowest cRTs occurred for the most frequent confidence rating regardless of whether this confidence rating was low or high. In addition, we found a strong across-subject correlation between RT and cRT, suggesting that response speed for both the decision and the confidence rating is influenced by a common factor. Our results show that cRT is not intrinsically linked to confidence and accuracy, and falsify models that propose post-decision evidence accumulation processes that result in lower cRTs for correct trials and trials with higher confidence.},
  file = {/home/lucas/Zotero_Articles/Chen and Rahnev - 2022 - What do confidence response times reveal about the.pdf}
}

