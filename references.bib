@article{sundh2020PreciseNotPrecise,
  title = {Precise/Not Precise ({{PNP}}): {{A Brunswikian}} Model That Uses Judgment Error Distributions to Identify Cognitive Processes},
  shorttitle = {Precise/Not Precise ({{PNP}})},
  author = {Sundh, Joakim and Collsiöö, August and Millroth, Philip and Juslin, Peter},
  date = {2020-09-28},
