@article{kangasraasio2019ParameterInferenceComputational,
  title = {Parameter {{Inference}} for {{Computational Cognitive Models}} with {{Approximate Bayesian Computation}}},
  author = {Kangasrääsiö, Antti and Jokinen, Jussi P. P. and Oulasvirta, Antti and Howes, Andrew and Kaski, Samuel},
  date = {2019-06},
  journaltitle = {Cognitive Science},
  shortjournal = {Cogn Sci},
  volume = {43},
