  volume = {34},
  number = {2},
  pages = {97--103},
  issn = {00283932},
  doi = {10.1016/0028-3932(95)00066-6},
  url = {https://linkinghub.elsevier.com/retrieve/pii/0028393295000666},
  urldate = {2022-10-19},
  abstract = {The quality of attempts at generating a random sequence of the numbers 1\textasciitilde 5 was studied in 30 patients with dementia of the Alzheimer type (DAT) and 30 elderly normal control (NC) subjects. Three main findings emerged: (1) DAT patients' subjective random sequences were more stereotyped (contained fewer digit combinations) than those of NC subjects. (2) This difference in response stereotypy was due to patients' enhanced tendency to arrange consecutive numbers in an ascending series ('counting bias'). (3) In the patient group, degree of sequential nonrandomness was positively correlated with overall severity of dementia and with the extent to which performance on neuropsychological tests specifically assessing executive functions (fluency, naming, error monitoring) was impaired. These results illustrate a loss of behavioral complexity in the course of dementia and are interpreted as reflecting a frontal dysexecutive syndrome in DAT.},
  langid = {english},
  keywords = {has_attachment,RGLR},
  file = {/home/lucas/Zotero_Articles/Brugger et al. - 1996 - Random number generation in dementia of the Alzhei.pdf}
}

