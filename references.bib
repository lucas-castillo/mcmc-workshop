  file = {/home/lucas/Zotero_Articles/Zhu et al. - 2022 - Clarifying the relationship between coherence and .pdf}
}

@article{zhu2022UnderstandingStructureCognitive,
  title = {Understanding the Structure of Cognitive Noise},
  author = {Zhu, Jian-Qiao and León-Villagrá, Pablo and Chater, Nick and Sanborn, Adam N},
  date = {2022},
  journaltitle = {PLoS Computational Biology},
  volume = {18},
  number = {8},
  pages = {e1010312},
  doi = {10.1371/journal.pcbi.1010312},
  abstract = {Human cognition is fundamentally noisy. While routinely regarded as a nuisance in experimental investigation, the few studies investigating properties of cognitive noise have found surprising structure. A first line of research has shown that inter-response-time distributions are heavy-tailed. That is, response times between subsequent trials usually change only a small amount, but with occasional large changes. A second, separate, line of research has found that participants’ estimates and response times both exhibit long-range autocorrelations (i.e., 1/f noise). Thus, each judgment and response time not only depends on its immediate predecessor but also on many previous responses. These two lines of research use different tasks and have distinct theoretical explanations: models that account for heavytailed response times do not predict 1/f autocorrelations and vice versa. Here, we find that 1/ f noise and heavy-tailed response distributions co-occur in both types of tasks. We also show that a statistical sampling algorithm, developed to deal with patchy environments, generates both heavy-tailed distributions and 1/f noise, suggesting that cognitive noise may be a functional adaptation to dealing with a complex world.},
  langid = {english},
  file = {/home/lucas/Zotero_Articles/Zhu et al. - 2022 - Understanding the structure of cognitive noise.pdf;/home/lucas/Zotero_Articles/Zhu et al. - 2022 - Understanding the structure of cognitive noise2.pdf}
}

