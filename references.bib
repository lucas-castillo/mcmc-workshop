@article{weber2025TestingReliabilityAnchoring,
  title = {Testing the Reliability of Anchoring Susceptibility Scores},
  author = {Weber, Lucia and Röseler, Lukas},
  date = {2025-02-28},
  journaltitle = {Europe’s Journal of Psychology},
  shortjournal = {Eur. J. Psychol.},
  volume = {21},
