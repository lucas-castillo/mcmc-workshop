}

@report{walasek2021IncomparabilityIncommensurabilityChoice,
  type = {preprint},
  title = {Incomparability and {{Incommensurability}} in {{Choice}}: {{No Common Currency}} of {{Value}}?},
  shorttitle = {Incomparability and {{Incommensurability}} in {{Choice}}},
  author = {Walasek, Lukasz and Brown, Gordon},
  date = {2021-11-04},
  institution = {PsyArXiv},
  doi = {10.31234/osf.io/suw47},
  url = {https://osf.io/suw47},
  urldate = {2022-11-04},
  abstract = {Models of decision-making typically assume the existence of some common currency of value, such as utility, happiness, or inclusive fitness. This common currency is taken to allow comparison of options and to underpin everyday choice. Here we suggest instead that there is no universal value scale, that incommensurability of value pervades everyday choice, and hence that many existing models of decision-making in both economics and psychology are fundamentally limited. We propose that choice objects can only be compared with reference to specific but nonuniversal “covering values”. These covering values may reflect decision-makers’ goals, motivations, or current states. A complete model of choice must accommodate the range of possible covering values. We show that abandoning the common currency assumption in models of judgment and decision-making necessitates rank-based and heuristic models that contrast radically with conventional utility-based approaches. We note that if there is no universal value scale then Arrow’s Impossibility Theorem places severe bounds on the rationality of individual decision-making, and hence that there is a deep link between the incommensurability of value, inconsistencies in human decision-making, and rank-based coding of value. More generally, incommensurability raises the question of whether it will ever be possible to develop singlequantity-maximizing models of decision-making.},
  langid = {english},
  file = {/home/lucas/Zotero_Articles/Walasek and Brown - 2021 - Incomparability and Incommensurability in Choice .pdf}
}

