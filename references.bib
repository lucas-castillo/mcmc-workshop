@online{genc2024VisualSomatomotorContribution,
  title = {Visual and {{Somatomotor Contribution}} to {{Random Number Generation During}} a {{Head Rotation Task}} in {{Augmented Reality}}},
  author = {Genc, Sura and Stäubli, Kim and Casanova, Luisa and Brugger, Peter and Roel Lesur, Marte and Lenggenhager, Bigna},
  date = {2024-11-19},
  doi = {10.31234/osf.io/a28qn},
  url = {https://osf.io/a28qn},
  urldate = {2024-12-23},
  abstract = {Embodied cognition research suggests a functional link between numerical and spatial cognition. Accordingly, numbers are assumed to be mentally represented on a “number line”, with smaller numbers on the left and larger numbers on the right in Western culture. Supporting this, prior findings show a numerical lateralization effect, where participants generating random numbers while turning their heads sideways produce more small numbers when facing left than when facing right. Here, we aimed to replicate and extend these findings by investigating the relative contributions of visual and proprioceptive signals to the spatialnumerical association. Our novel augmented reality setup enabled us to separate visual and proprioceptive cues for horizontal head rotation. We hypothesized that participants would generate more small numbers when facing left in the ordinary visual perspective (normal condition, i.e., proprioceptive and visual cues aligned), and that this tendency would be reduced when the visual axis was inverted (inverted condition). We also used a rod and frame task to assess the individuals’ visual dependency and a newly developed side detection task for head somatomotor rotation sensitivity. We hypothesized that visual dependency would correlate with numerical lateralization, while an inverted pattern would be observed for head rotation sensitivity. Results showed moderate evidence against the effect of head direction, indicating that we were unable to replicate the previously reported effect. Additionally, the moderate evidence against the effect of condition suggests that inverting the visual field did not reduce the frequency of small numbers generated when looking left. These findings imply that the spatial bias in number generation may be less robust or may not generalize to head-mounted display setups.},
  langid = {english},
  pubstate = {prepublished},
  keywords = {RGLR},
  file = {/home/lucas/Zotero/storage/5XU4JAJK/Genc et al. - 2024 - Visual and Somatomotor Contribution to Random Numb.pdf}
}

@article{german2023RapidRuntimeLearning,
