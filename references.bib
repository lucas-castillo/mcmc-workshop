@article{bramley2018IntuitiveExperimentationPhysical,
  title = {Intuitive Experimentation in the Physical World},
  author = {Bramley, Neil R. and Gerstenberg, Tobias and Tenenbaum, Joshua B. and Gureckis, Todd M.},
