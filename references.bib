@online{fischer2024ReuseNeedlePay,
  title = {"{{To}} Reuse a Needle or to Pay Digitally"? {{A}} Comparative Analysis of Researchers' and Laypeople's Perspectives on Risky Choices and Associated Mechanisms},
  shorttitle = {"{{To}} Reuse a Needle or to Pay Digitally"?},
  author = {Fischer, Olivia and Lob, Aaron Benjamin and Frey, Renato},
  date = {2024-11-22},
  doi = {10.31234/osf.io/h43cj},
  url = {https://osf.io/h43cj},
  urldate = {2024-12-23},
  abstract = {The behavioral sciences have long studied how people make risky choices, yet it remains unclear to what degree the choices used by researchers (e.g., to develop and calibrate novel measurement tools) reflect those made by people in real life. To address this question, we compared risky choices in the focus of researchers’ and laypeople’s perspectives. In a first study, we examined the overlap between these perspectives by determining how many choices they have in common. Leveraging large language models and calibrating semantic similarities with human judgments, we found an overlap of only 18\%. To further examine the implications of this mismatch in terms of the psychological mechanisms that these various choices may tap into, we conducted a second study in which 825 participants rated the perceived relevance of seven classes of psychological mechanisms to their decision making in choices from both perspectives. Bayesian mixed effects models revealed credible differences between the perspectives in five out of seven classes of mechanisms. These findings suggest that current theories of decision making may explain only a narrow scope of choices, underscoring the need for the behavioral sciences to realign their focus to better capture the complexity of real-life decision making.},
  langid = {english},
  pubstate = {prepublished},
  file = {/home/lucas/Zotero/storage/5YDGMD4F/Fischer et al. - 2024 - To reuse a needle or to pay digitally A compara.pdf}
}

